{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20"
  },
  "steps": {
    "build": {
      "commands": [
        "sh -c 'cd server && npm install && npx prisma generate && npm run build'"
      ]
    }
  },
  "deploy": {
    "startCommand": "sh -c 'cd server && npm start'"
  }
}