generator client {
  provider = "prisma-client-js"
}

model Customer {
  id           String      @id @default(uuid())
  ownerId      String?
  owner        Owner?      @relation(fields: [ownerId], references: [id])
  code        String      @unique
  name        String
  channel     String?     // 渠道：电商、线下门店、批发商等
  region      String?     // 区域：华东、华北、华南等
  level       CustomerLevel @default(NORMAL)
  
  // 联系信息
  contact     String
  phone       String
  
  // 地址信息
  province    String
  city        String
  district    String?
  address     String
  latitude    Float?
  longitude   Float?
  
  // 配送设置
  deliveryStartTime String?  // 配送开始时间 如：09:00
  deliveryEndTime   String?  // 配送结束时间 如：18:00
  specialRequirements String? // 特殊要求：夜间配送、需提前预约等
  
  // 签收规则
  inspectionRequired  Boolean @default(true)  // 是否需要验货
  certificateRequired Boolean @default(false) // 是否需要凭证
  signatureNote      String? // 签收备注
  
  // 状态
  status       CustomerStatus @default(ACTIVE)
  remark       String?

  // 关联
  contracts    Contract[]
  orders       Order[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum CustomerLevel {
  VIP
  NORMAL
  POTENTIAL
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model Contract {
  id           String      @id @default(uuid())
  contractNo   String      @unique
  name         String      // 合同名称
  
  // 关联客户
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  
  // 合同信息
  startDate    DateTime
  endDate      DateTime
  amount       Decimal?    @db.Decimal(12, 2)  // 合同金额
  discount     Decimal?    @db.Decimal(5, 2)   // 合同折扣（如 0.85 表示 85 折）
  
  // 计价条款
  pricingTerms Json?       // 差异化计价条款（JSON格式）
  // {
  //   "baseRate": 10,        // 基础费率
  //   "distanceRates": {...}, // 距离计价
  //   "weightRates": {...},   // 重量计价
  //   "volumeRates": {...},   // 体积计价
  //   "specialRates": {...},  // 特殊服务费
  //   "discounts": {...}      // 折扣条款
  // }
  
  // 服务条款
  serviceTerms String?     // 服务条款描述
  specialTerms String?     // 特殊条款
  
  // 状态
  status       ContractStatus @default(ACTIVE)
  autoRenew    Boolean @default(false)  // 是否自动续约

  // 合同附件
  fileUrl      String?     // 合同文件URL
  fileName     String?     // 合同文件名
  fileSize     Int?       // 合同文件大小

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model SupplierContract {
  id           String      @id @default(uuid())
  contractNo   String      @unique
  name         String      // 合同名称

  // 关联供应商
  supplierId   String
  supplier     Supplier    @relation(fields: [supplierId], references: [id])

  // 合同信息
  startDate    DateTime?
  endDate      DateTime?
  amount       Decimal?    @db.Decimal(12, 2)  // 合同金额
  discount     Decimal?    @db.Decimal(5, 2)   // 合同折扣

  // 条款
  serviceTerms String?     // 服务条款描述
  specialTerms String?     // 特殊条款

  // 状态
  status       ContractStatus @default(DRAFT)

  // 合同附件
  fileUrl      String?     // 合同文件URL
  fileName     String?     // 合同文件名
  fileSize     Int?        // 合同文件大小

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([supplierId])
}

enum ContractStatus {
  DRAFT       // 草稿
  PENDING     // 待生效
  ACTIVE      // 生效中
  EXPIRED     // 已过期
  TERMINATED  // 已终止
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum PermissionType {
  READ     // 只读
  WRITE    // 读写
  NONE     // 无权限
}

enum OrderStatus {
  PENDING       // 待拣货
  PICKING       // 拣货中
  OUTBOUND_REVIEW  // 出库审核中
  DISPATCHING   // 待运力调度
  DISPATCHED    // 已调度
  IN_TRANSIT    // 运输中
  DELIVERED     // 已送达
  COMPLETED     // 已完成
  RETURNING     // 退货中
  RETURNED      // 已退货退款
  CANCELLED     // 已取消
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  isAdmin   Boolean  @default(false)  // 是否系统管理员
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pickerOrders  PickOrder[] @relation("PickerOrders")
  approverOrders PickOrder[] @relation("ApproverOrders")
  userOwners    UserOwner[]
}

model UserOwner {
  id        String   @id @default(uuid())
  userId    String
  ownerId   String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, ownerId])
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique  // 角色代码
  name        String   // 角色名称
  description String?  // 角色描述
  permissions Json     // 权限配置，JSON格式
  // {
  //   "oms": { "orders": "WRITE", "import": "NONE", ... },
  //   "wms": { "inbound": "WRITE", "outbound": "WRITE", ... },
  //   "tms": { "dispatch": "WRITE", "vehicle": "WRITE", ... },
  //   "afterSales": { "returns": "WRITE", "refund": "WRITE", ... },
  //   "system": { "users": "WRITE", "owners": "WRITE", ... }
  // }
  isDefault   Boolean  @default(false)  // 是否为默认角色
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userOwners  UserOwner[]
}

model Owner {
  id              String   @id @default(uuid())
  name            String
  contact         String?
  phone           String?
  productTags     String[]
  warehouseLocation String?
  province        String?
  city            String?
  address         String?
  latitude        Float?
  longitude       Float?
  status          String   @default("SERVING")
  isSelfOperated  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]
  warehouses      Warehouse[]
  returnOrders    ReturnOrder[]
  products        Product[]
  productSkus     ProductSKU[]
  bundles         BundleSKU[]
  customers       Customer[]
  suppliers       Supplier[]
  carriers        Carrier[]
  purchaseOrders  PurchaseOrder[]
  userOwners      UserOwner[]
}

model ProductCategory {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  subCategories ProductSubCategory[]
  brands    ProductBrand[]
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSubCategory {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id])
  products   Product[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProductBrand {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id])
  description String?
  products    Product[]
  packagings  BrandPackaging[]
  specs       BrandSpec[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PackagingOption {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  brandPackagings BrandPackaging[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SpecOption {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  brandSpecs BrandSpec[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandPackaging {
  id          String   @id @default(uuid())
  brandId     String
  packagingId String
  brand       ProductBrand @relation(fields: [brandId], references: [id])
  packaging   PackagingOption @relation(fields: [packagingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([brandId, packagingId])
}

model BrandSpec {
  id          String   @id @default(uuid())
  brandId     String
  specId      String
  brand       ProductBrand @relation(fields: [brandId], references: [id])
  spec        SpecOption @relation(fields: [specId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([brandId, specId])
}

model Supplier {
  id          String   @id @default(uuid())
  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id])
  code        String   @unique
  name        String
  contact     String?
  phone       String?
  email       String?
  address     String?
  province    String?
  city        String?
  district    String?
  productTags String[]
  status      SupplierStatus @default(ACTIVE)
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts      SupplierContract[]
  skuBatches     SKUBatch[]
  bundleBatches  BundleBatch[]
  materialBatches MaterialBatch[]
  purchaseOrders PurchaseOrder[]
  supplierProducts SupplierProduct[]
  supplierMaterials SupplierMaterial[]
  inboundOrderItems InboundOrderItem[]
}

model SupplierProduct {
  id          String   @id @default(uuid())

  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  itemType    ItemType  // PRODUCT, BUNDLE
  skuId       String?
  bundleId    String?

  sku         ProductSKU? @relation(fields: [skuId], references: [id])
  bundle      BundleSKU?  @relation(fields: [bundleId], references: [id])

  price       Decimal?  @db.Decimal(12, 2)  // 供应价
  minQty      Int?      @default(1)         // 最小采购量
  leadDays    Int?      // 交货周期(天)

  status      SupplierProductStatus @default(ACTIVE)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplierId])
  @@index([skuId])
  @@index([bundleId])
}

model SupplierMaterial {
  id          String   @id @default(uuid())

  name        String   // 原材料/其他商品名称
  category    String   // MATERIAL 或 OTHER
  unit        String?  // 单位(个/箱/千克/吨等)
  price       Decimal? @db.Decimal(12, 2)  // 供应价
  minQty      Int?     @default(1)         // 最小采购量
  leadDays    Int?     // 交货周期(天)

  status      SupplierProductStatus @default(ACTIVE)

  supplierId  String?  // 所属供应商
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrderItems PurchaseOrderItem[]
  batches     MaterialBatch[]
  materialStocks MaterialStock[]
}

enum SupplierProductStatus {
  ACTIVE      // 启用
  INACTIVE    // 停用
}

enum SupplierStatus {
  ACTIVE      // 启用
  INACTIVE    // 停用
}

// ========== 采购模块 ==========

model PurchaseOrder {
  id              String   @id @default(uuid())
  orderNo         String   @unique
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id])

  warehouseId     String?
  ownerId         String?
  owner           Owner?   @relation(fields: [ownerId], references: [id])

  status          PurchaseOrderStatus @default(PENDING)
  orderDate       DateTime
  expectedDate    DateTime?
  actualDate      DateTime?

  totalAmount     Decimal?  @db.Decimal(12, 2)
  remark          String?

  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           PurchaseOrderItem[]

  inboundOrders   InboundOrder[]

  @@index([supplierId])
  @@index([warehouseId])
  @@index([ownerId])
  @@index([status])
}

enum PurchaseOrderStatus {
  PENDING      // 待确认
  CONFIRMED    // 已确认
  PARTIAL      // 部分到货
  ARRIVED      // 全部到货
  CANCELLED    // 已取消
}

model PurchaseOrderItem {
  id                  String   @id @default(uuid())
  purchaseOrderId     String
  purchaseOrder       PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  itemType            ItemType
  skuId               String?
  bundleId            String?
  supplierMaterialId  String?   // 当类型是 MATERIAL 或 OTHER 时关联供应商原材料表

  sku                 ProductSKU? @relation(fields: [skuId], references: [id])
  bundle              BundleSKU? @relation(fields: [bundleId], references: [id])
  supplierMaterial    SupplierMaterial? @relation(fields: [supplierMaterialId], references: [id])

  skuBatchId          String?
  bundleBatchId       String?

  quantity            Int
  receivedQuantity    Int      @default(0)
  price               Decimal?  @db.Decimal(12, 2)
  amount              Decimal?  @db.Decimal(12, 2)

  productionDate      DateTime?
  expireDate          DateTime?

  status              PurchaseItemStatus @default(PENDING)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([skuId])
  @@index([bundleId])
}

enum PurchaseItemStatus {
  PENDING       // 待到货
  PARTIAL       // 部分到货
  RECEIVED      // 已到货
  REJECTED      // 拒收
  CANCELLED     // 取消
}

enum ItemType {
  PRODUCT
  BUNDLE
  MATERIAL
  OTHER
}

model Product {
  id             String   @id @default(uuid())
  ownerId        String?
  owner          Owner?   @relation(fields: [ownerId], references: [id])
  name           String
  brandId        String
  brand          ProductBrand @relation(fields: [brandId], references: [id])
  categoryId     String
  category       ProductCategory @relation(fields: [categoryId], references: [id])
  subCategoryId  String?
  subCategory    ProductSubCategory? @relation(fields: [subCategoryId], references: [id])
  status         String   @default("ACTIVE")
  skus           ProductSKU[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProductSKU {
  id          String   @id @default(uuid())
  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  skuCode     String   @unique  // 自动生成的 SKU 编码
  packaging   String
  spec        String
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
  pickOrderItems PickOrderItem[]
  returnItems  ReturnItem[]
  stocks     Stock[]
  stockLocks StockLock[]
  stockIns   StockIn[]
  bundleItems BundleSKUItem[]
  transferItems StockTransferItem[]
  skuBatches  SKUBatch[]
  purchaseOrderItems PurchaseOrderItem[]
  supplierProducts SupplierProduct[]
}

model BundleSKU {
  id          String   @id @default(uuid())
  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id])
  name        String
  skuCode     String   @unique  // 自动生成的 SKU 编码，格式：B_品类码(4位) + 包装码(1位) + 序号(4位)
  packaging   String
  spec        String
  price       Decimal  @db.Decimal(10, 2)
  image       String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       BundleSKUItem[]
  returnItems ReturnItem[]
  stocks      BundleStock[]
  stockLocks  BundleStockLock[]
  stockIns   BundleStockIn[]
  pickOrderItems PickOrderItem[]
  orderItems  OrderItem[]
  transferItems StockTransferItem[]
  bundleBatches BundleBatch[]
  supplierProducts SupplierProduct[]
  purchaseOrderItems PurchaseOrderItem[]
}

model BundleSKUItem {
  id          String    @id @default(uuid())
  bundleId    String
  bundle      BundleSKU @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  skuId       String
  sku         ProductSKU @relation(fields: [skuId], references: [id])
  quantity    Int       // 该商品在套装中的数量
  createdAt   DateTime  @default(now())

  @@unique([bundleId, skuId])
}

model BundleStock {
  id              String    @id @default(uuid())
  bundleId        String
  bundle          BundleSKU @relation(fields: [bundleId], references: [id])
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  bundleBatchId   String
  bundleBatch     BundleBatch @relation(fields: [bundleBatchId], references: [id])
  totalQuantity   Int       @default(0)
  lockedQuantity  Int       @default(0)
  availableQuantity Int      @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([warehouseId, locationId, bundleBatchId])
}

model BundleStockLock {
  id          String   @id @default(uuid())
  bundleId    String
  bundle      BundleSKU @relation(fields: [bundleId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])
  bundleBatchId String
  bundleBatch BundleBatch @relation(fields: [bundleBatchId], references: [id])
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quantity    Int
  createdAt   DateTime @default(now())
  pickOrderItems PickOrderItem[]
}

model MaterialStock {
  id              String    @id @default(uuid())
  supplierMaterialId String
  supplierMaterial  SupplierMaterial @relation(fields: [supplierMaterialId], references: [id])
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  materialBatchId String
  materialBatch   MaterialBatch @relation(fields: [materialBatchId], references: [id])
  totalQuantity   Int       @default(0)
  lockedQuantity  Int       @default(0)
  availableQuantity Int     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([warehouseId, locationId, materialBatchId])
}

model BundleStockIn {
  id          String    @id @default(uuid())
  bundleId    String
  bundle      BundleSKU @relation(fields: [bundleId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])
  bundleBatchId String
  bundleBatch BundleBatch @relation(fields: [bundleBatchId], references: [id])
  quantity    Int
  remark      String?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  executedAt  DateTime?
}

model Order {
  id          String      @id @default(uuid())
  orderNo     String      @unique
  ownerId     String
  owner       Owner       @relation(fields: [ownerId], references: [id])
  warehouseId String
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  receiver    String
  phone       String
  province    String
  city        String
  address     String
  latitude    Float?      // 纬度
  longitude   Float?      // 经度
  totalAmount Decimal     @db.Decimal(12, 2)
  contractDiscount Float?  // 客户协议折扣，如 0.8 表示 8折
  status      OrderStatus @default(PENDING)
  items       OrderItem[]
  stockLocks StockLock[]
  bundleStockLocks BundleStockLock[]
  dispatchOrders DispatchOrder[]
  returnOrders ReturnOrder[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId      String?
  sku        ProductSKU? @relation(fields: [skuId], references: [id])
  bundleId   String?
  bundle     BundleSKU? @relation(fields: [bundleId], references: [id])
  productName String
  packaging  String
  spec       String
  price      Decimal  @db.Decimal(10, 2)
  quantity   Int
  subtotal   Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
}

enum PickStatus {
  PENDING    // 待拣货
  PICKING    // 拣货中
  PICKED     // 已拣货
  PICK_FAILED // 拣货失败
  COMPLETED  // 已完成
  CANCELLED  // 已取消
}

model PickOrder {
  id          String      @id @default(uuid())
  pickNo     String      @unique
  orderIds    String      // 多个订单ID用逗号分隔
  status     PickStatus  @default(PENDING)
  items      PickOrderItem[]
  pickerId   String?     // 拣货人ID
  picker     User?       @relation("PickerOrders", fields: [pickerId], references: [id])
  approverId String?     // 审核人ID
  approver   User?       @relation("ApproverOrders", fields: [approverId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model PickOrderItem {
  id         String      @id @default(uuid())
  pickOrderId String
  pickOrder  PickOrder   @relation(fields: [pickOrderId], references: [id], onDelete: Cascade)
  skuId      String?
  sku        ProductSKU?  @relation(fields: [skuId], references: [id])
  bundleId   String?
  bundle     BundleSKU?  @relation(fields: [bundleId], references: [id])
  productName String
  packaging  String
  spec       String
  quantity   Int
  skuBatchId String?
  skuBatch   SKUBatch?   @relation(fields: [skuBatchId], references: [id])
  bundleBatchId String?
  bundleBatch BundleBatch? @relation(fields: [bundleBatchId], references: [id])
  warehouseLocation String
  stockLockId String?
  stockLock  StockLock? @relation(fields: [stockLockId], references: [id])
  bundleStockLockId String?
  bundleStockLock BundleStockLock? @relation(fields: [bundleStockLockId], references: [id])
}

enum WarehouseType {
  NORMAL    // 普通仓
  COLD      // 冷链仓
  MATERIAL  // 原料仓
}

enum WarehouseStatus {
  ACTIVE      // 启用
  INACTIVE    // 停用
  MAINTENANCE // 维护中
}

model Warehouse {
  id          String          @id @default(uuid())
  code        String          @unique
  name        String
  type        WarehouseType   @default(NORMAL)
  status      WarehouseStatus @default(ACTIVE)
  province    String?
  city        String?
  address     String?
  latitude    Float?          // 仓库纬度
  longitude   Float?          // 仓库经度
  ownerId     String?
  owner       Owner?          @relation(fields: [ownerId], references: [id])
  manager       String?         // 仓库管理员
  managerPhone String?        // 管理员电话
  businessStartTime String?   // 营业开始时间
  businessEndTime   String?   // 营业结束时间
  zones       Zone[]
  stocks     Stock[]
  stockIns   StockIn[]
  stockLocks StockLock[]
  orders     Order[]
  vehicles   Vehicle[]
  drivers    Driver[]
  dispatches Dispatch[]
  returnOrders ReturnOrder[]
  bundleStocks    BundleStock[]
  bundleStockLocks BundleStockLock[]
  bundleStockIns BundleStockIn[]
  materialStocks MaterialStock[]
  stockTransfers StockTransfer[]
  inboundOrders InboundOrder[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Zone {
  id          String    @id @default(uuid())
  code        String
  name        String
  type        String    @default("STORAGE")  // INBOUND-入库区 STORAGE-存储区 PICKING-拣货区 SHIPPING-发货区 RETURNING-退货区 DAMAGED-残次品区
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  shelves     Shelf[]
  transfersFrom StockTransfer[] @relation("TransferFromZone")
  transfersTo   StockTransfer[] @relation("TransferToZone")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, code])
}

model Shelf {
  id          String    @id @default(uuid())
  code        String    // 货架编码 R001, R002...
  name        String?   // 货架名称（如需）
  type        String    @default("HEAVY")  // HEAVY-重型货架 FLOW-流利架 LIGHT-轻型货架
  status      String    @default("ACTIVE") // ACTIVE-启用 INACTIVE-禁用
  zoneId      String
  zone        Zone      @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  locations   Location[]

  @@unique([zoneId, code])
  createdAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Location {
  id        String    @id @default(uuid())
  shelfId   String
  shelf     Shelf     @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  level     Int       // 第几层（必填）
  position  Int?      // 同一层的第几个位置（可选，更精确时使用）
  stockIns    StockIn[]
  stocks      Stock[]
  stockLocks  StockLock[]
  bundleStocks     BundleStock[]
  bundleStockLocks BundleStockLock[]
  bundleStockIns   BundleStockIn[]
  materialStocks   MaterialStock[]
  transferFrom StockTransferItem[] @relation("TransferFromLocation")
  transferTo   StockTransferItem[] @relation("TransferToLocation")
  inboundOrderItems InboundOrderItem[]

  @@unique([shelfId, level, position])
  createdAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum LockStatus {
  LOCKED      // 已锁定（待拣货）
  RELEASED    // 已释放（订单取消）
  USED        // 已使用（拣货完成）
}

enum TransferStatus {
  PENDING      // 待移库
  IN_TRANSIT   // 移库中
  COMPLETED    // 已完成
  CANCELLED    // 已取消
}

enum TransferType {
  ZONE_TRANSFER     // 库区调拨
  QUALITY_INSPECT   // 质检移库
  DAMAGED          // 报废
}

model StockTransfer {
  id              String         @id @default(uuid())
  transferNo      String         @unique
  warehouseId     String
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  type            TransferType   @default(ZONE_TRANSFER)
  fromZoneId      String?
  fromZone        Zone?          @relation("TransferFromZone", fields: [fromZoneId], references: [id])
  toZoneId        String?
  toZone          Zone?          @relation("TransferToZone", fields: [toZoneId], references: [id])
  status          TransferStatus @default(PENDING)
  remark          String?
  operator        String?
  items           StockTransferItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  executedAt      DateTime?
  @@index([warehouseId])
  @@index([status])
}

model StockTransferItem {
  id              String         @id @default(uuid())
  transferId      String
  transfer        StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  itemType        ItemType       @default(PRODUCT)
  skuId           String?
  sku             ProductSKU?    @relation(fields: [skuId], references: [id])
  bundleId        String?
  bundle          BundleSKU?     @relation(fields: [bundleId], references: [id])
  fromLocationId  String?
  fromLocation    Location?      @relation("TransferFromLocation", fields: [fromLocationId], references: [id])
  toLocationId    String?
  toLocation      Location?      @relation("TransferToLocation", fields: [toLocationId], references: [id])
  skuBatchId      String?
  skuBatch        SKUBatch?      @relation(fields: [skuBatchId], references: [id])
  bundleBatchId   String?
  bundleBatch     BundleBatch?   @relation(fields: [bundleBatchId], references: [id])
  quantity        Int
  createdAt       DateTime       @default(now())
  @@index([transferId])
  @@index([skuId])
  @@index([bundleId])
}

model Stock {
  id              String    @id @default(uuid())
  skuId           String
  sku             ProductSKU @relation(fields: [skuId], references: [id])
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  skuBatchId      String
  skuBatch        SKUBatch @relation(fields: [skuBatchId], references: [id])
  totalQuantity   Int       @default(0)
  lockedQuantity  Int       @default(0)
  availableQuantity Int     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  stockIns        StockIn[]

  @@unique([warehouseId, locationId, skuBatchId])
}

model StockLock {
  id          String      @id @default(uuid())
  skuId       String
  sku         ProductSKU  @relation(fields: [skuId], references: [id])
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id])
  warehouseId String
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  locationId  String?
  location    Location?   @relation(fields: [locationId], references: [id])
  skuBatchId  String
  skuBatch    SKUBatch    @relation(fields: [skuBatchId], references: [id])
  quantity    Int
  status      LockStatus  @default(LOCKED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  pickOrderItems PickOrderItem[]
}

model StockIn {
  id          String    @id @default(uuid())
  stockId     String?
  stock       Stock?    @relation(fields: [stockId], references: [id])
  skuId       String
  sku         ProductSKU @relation(fields: [skuId], references: [id])
  warehouseId  String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])
  skuBatchId  String
  skuBatch    SKUBatch @relation(fields: [skuBatchId], references: [id])
  quantity    Int
  remark      String?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  executedAt  DateTime?
  operator    String?
}

enum InboundSource {
  PURCHASE    // 采购入库
  RETURN      // 退货入库
  TRANSFER    // 调拨入库
  OTHER       // 其他入库
}

enum InboundStatus {
  PENDING       // 待收货
  ARRIVED       // 已到货（到货登记）
  RECEIVING     // 收货中（验收中）
  RECEIVED      // 已收货（验收完成）
  PUTAWAY       // 上架中
  COMPLETED     // 已完成
  CANCELLED     // 已取消
}

model InboundOrder {
  id          String    @id @default(uuid())
  inboundNo   String    @unique
  source     InboundSource @default(PURCHASE)  // 来源
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  remark      String?

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // 到货信息
  arrivalQuantity Int?    // 到货数量
  palletNo       String? // 托盘号
  vehicleNo      String? // 车牌号
  arrivedAt       DateTime? // 到货时间

  // 执行信息
  receivedAt DateTime? // 验收完成时间
  putawayAt  DateTime? // 上架完成时间

  // ERP 回传
  erpSyncStatus String?  // PENDING / SYNCED / FAILED
  erpSyncAt    DateTime?

  status      InboundStatus @default(PENDING)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items       InboundOrderItem[]

  @@index([warehouseId])
  @@index([status])
}

model InboundOrderItem {
  id          String    @id @default(uuid())
  inboundId   String
  inbound     InboundOrder @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  type        ItemType  // 使用现有的 ItemType enum
  skuId       String?
  bundleId    String?
  supplierMaterialId String?
  supplierId  String?   // 供应商ID
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])

  // 数量
  expectedQuantity Int?   // 计划数量
  receivedQuantity Int?   // 实收数量

  // 批次 - 根据 type 关联不同的批次表
  skuBatchId      String?
  skuBatch        SKUBatch? @relation(fields: [skuBatchId], references: [id])
  bundleBatchId   String?
  bundleBatch     BundleBatch? @relation(fields: [bundleBatchId], references: [id])
  materialBatchId     String?
  materialBatch      MaterialBatch? @relation(fields: [materialBatchId], references: [id])

  // 验收结果
  inspectionResult String? // OK / SHORT / DAMAGED
  inspectionNote  String? // 验收备注

  // 上架状态
  putawayStatus   String? // PENDING / IN_PROGRESS / COMPLETED

  quantity    Int

  @@index([inboundId])
}

model StockOut {
  id          String    @id @default(uuid())
  orderId     String
  skuId       String?
  bundleId    String?
  warehouseId String
  locationId  String?
  skuBatchId  String?
  skuBatch    SKUBatch? @relation(fields: [skuBatchId], references: [id])
  bundleBatchId String?
  bundleBatch BundleBatch? @relation(fields: [bundleBatchId], references: [id])
  quantity    Int
  remark      String?
  createdAt   DateTime  @default(now())
  operator    String?

  @@index([orderId])
  @@index([warehouseId])
  @@index([skuId])
  @@index([bundleId])
  @@index([locationId])
  @@index([skuBatchId])
  @@index([bundleBatchId])
}

enum VehicleStatus {
  AVAILABLE  // 空闲
  IN_TRANSIT // 配送中
  MAINTENANCE // 维修
  DISABLED  // 停用
}

model Vehicle {
  id           String        @id @default(uuid())
  licensePlate String        // 车牌号
  vehicleType  String        // 车型(小面/中面/厢货)
  brand        String?       // 品牌
  model        String?       // 型号
  capacity     Float         // 载重(吨)
  volume       Float?        // 容积(立方米)
  licenseNo    String?       // 行驶证号
  insuranceNo  String?        // 保险单号
  status       VehicleStatus @default(AVAILABLE)
  warehouseId  String
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  latitude     Float?        // 当前纬度
  longitude    Float?        // 当前经度
  location     String?       // 当前位置描述
  address      String?       // 详细地址
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  dispatches   Dispatch[]
  drivers      Driver[]
}

enum DriverStatus {
  AVAILABLE  // 空闲
  IN_TRANSIT // 配送中
  RESTING    // 休息
  DISABLED   // 停用
}

model Driver {
  id          String        @id @default(uuid())
  name        String        // 姓名
  phone       String        // 电话
  licenseNo   String        // 驾驶证号
  licenseTypes String[]      // 准驾车型
  status      DriverStatus  @default(AVAILABLE)
  warehouseId String
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id])
  vehicleId   String?
  vehicle     Vehicle?      @relation(fields: [vehicleId], references: [id])
  latitude    Float?        // 当前纬度
  longitude   Float?        // 当前经度
  location    String?       // 当前位置描述
  address     String?       // 详细地址
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  dispatches  Dispatch[]
}

enum DispatchStatus {
  PENDING     // 待发运
  IN_TRANSIT  // 配送中
  COMPLETED   // 已完成
  CANCELLED   // 已取消
}

model Dispatch {
  id             String          @id @default(uuid())
  dispatchNo     String          @unique // 配送单号
  vehicleSource  String          @default("WAREHOUSE") // WAREHOUSE 或 CARRIER
  vehicleId      String?         // 自有车辆ID（当 vehicleSource = WAREHOUSE 时使用）
  vehicle        Vehicle?        @relation(fields: [vehicleId], references: [id])
  carrierVehicleId String?       // 承运商车辆ID（当 vehicleSource = CARRIER 时使用）
  carrierVehicle CarrierVehicle? @relation(fields: [carrierVehicleId], references: [id])
  driverId       String?         // 承运商车辆时可能为空
  driver         Driver?         @relation(fields: [driverId], references: [id])
  warehouseId     String
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])
  status         DispatchStatus  @default(PENDING)
  plannedRoute   Json?           // 规划路线
  actualRoute   Json?           // 实际路线
  totalDistance  Float?          // 总距离(公里)
  departureTime  DateTime?       // 发车时间
  completedTime  DateTime?       // 完成时间
  orderCount     Int             // 订单数量
  totalWeight    Int             // 总重量(件)
  remark         String?         // 备注
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orders         DispatchOrder[]
}

enum DispatchOrderStatus {
  PENDING    // 待配送
  DELIVERED  // 已配送
  SIGNED     // 已签收
}

model DispatchOrder {
  id          String              @id @default(uuid())
  dispatchId  String
  dispatch    Dispatch            @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  orderId     String
  order       Order              @relation(fields: [orderId], references: [id])
  latitude    Float?              // 代理点纬度
  longitude   Float?              // 代理点经度
  agentName   String?             // 代理点名称
  status      DispatchOrderStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// ============== 退货相关模型 ==============

enum ReturnStatus {
  RETURN_REQUESTED   // 客户发起退货申请
  RETURN_SHIPPED     // 客户已发货/等待仓库收货
  RETURN_RECEIVING   // 仓库收货中
  RETURN_QUALIFIED   // 验收合格（全部合格）
  RETURN_PARTIAL_QUALIFIED // 部分合格
  RETURN_REJECTED    // 验收拒收（全部不合格）
  RETURN_STOCK_IN    // 退货入库完成
  REFUNDED           // 已完成退款
  CANCELLED          // 已取消
}

enum RefundStatus {
  PENDING    // 待退款
  PROCESSING // 退款中
  COMPLETED  // 已退款
  FAILED     // 退款失败
}

model ReturnOrder {
  id           String       @id @default(uuid())
  returnNo     String       @unique // 退货单号
  orderId      String       // 原订单ID
  order        Order        @relation(fields: [orderId], references: [id])

  ownerId      String
  owner        Owner        @relation(fields: [ownerId], references: [id])

  warehouseId  String
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])

  status      ReturnStatus @default(RETURN_REQUESTED)
  reason      String       // 退货原因

  refundAmount Decimal?    @db.Decimal(12, 2) // 退款金额
  refundStatus RefundStatus @default(PENDING)

  receiverName String?     // 收货人
  receiverPhone String?   // 收货电话
  receiverAddress String? // 收货地址

  trackingNo String?     // 快递单号
  logisticsCompany String? // 物流公司

  operatorName String?     // 操作人

  items       ReturnItem[]
  logs        ReturnLog[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ReturnItem {
  id               String      @id @default(uuid())
  returnOrderId    String
  returnOrder     ReturnOrder @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)

  orderItemId     String      // 原订单商品ID
  skuId           String?
  sku             ProductSKU? @relation(fields: [skuId], references: [id])
  bundleId        String?
  bundle          BundleSKU?  @relation(fields: [bundleId], references: [id])

  productName     String       // 商品名称（冗余）
  packaging      String       // 包装
  spec           String       // 规格

  quantity       Int          // 退货数量
  stockOutId     String?      // 对应出库记录ID
  qualifiedQuantity Int       @default(0) // 合格数量
  rejectedQuantity Int       @default(0) // 拒收数量

  remark         String?      // 备注

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum ReturnAction {
  CREATE           // 创建退货单
  SHIPPED          // 客户发货
  RECEIVE          // 仓库收货
  QUALIFY          // 验收确认（全部合格）
  PARTIAL          // 部分合格
  REJECT           // 拒收（全部不合格）
  STOCK_IN         // 退货入库
  REFUND           // 退款
  CANCEL           // 取消
}

model ReturnLog {
  id            String       @id @default(uuid())
  returnOrderId String
  returnOrder   ReturnOrder  @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)

  action       ReturnAction
  beforeStatus String?
  afterStatus  String?

  operatorName String?
  remark       String?

  createdAt    DateTime     @default(now())
}

// 承运商管理
model Carrier {
  id           String   @id @default(uuid())
  code        String   @unique // 承运商编码
  name        String   // 承运商名称
  type        CarrierType @default(INDIVIDUAL) // 承运商类型：个体/企业
  level       CarrierLevel @default(C) // 承运商等级：A/B/C

  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id])

  // 资质信息
  businessLicenseNo  String? // 营业执照号
  businessLicenseUrl String? // 营业执照图片
  transportLicenseNo String? // 道路运输经营许可证号
  transportLicenseUrl String? // 道路运输经营许可证图片

  // 服务能力
  serviceTypes    String[] // 服务类型：长途运输、短途配送、冷链运输等
  coverageAreas   String[] // 覆盖区域
  vehicleTypes    String[] // 可用车型

  // 联系信息
  contact     String?
  phone       String?
  province    String?
  city        String?
  address     String?

  // 状态
  status      CarrierStatus @default(PENDING) // PENDING/APPROVED/REJECTED/SUSPENDED

  // 审核信息
  rejectionReason String? // 拒绝原因
  approvedAt      DateTime? // 审核通过时间
  approvedBy      String? // 审核人

  // 合同
  contracts   CarrierContract[]

  // 车辆
  vehicles    CarrierVehicle[]

  remark     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum CarrierType {
  INDIVIDUAL // 个体
  COMPANY    // 企业
}

enum CarrierLevel {
  A // 优质
  B // 良好
  C // 合格
}

enum CarrierStatus {
  PENDING    // 待审核
  APPROVED  // 已通过
  REJECTED  // 已拒绝
  SUSPENDED // 已暂停
}

// 承运商合同
model CarrierContract {
  id           String   @id @default(uuid())
  carrierId    String
  carrier      Carrier  @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  contractNo   String   @unique // 合同编号
  name         String   // 合同名称
  startDate    DateTime // 合同开始日期
  endDate      DateTime // 合同结束日期

  // 合同条款
  serviceTerms String?  // 服务条款
  priceTerms   String?  // 价格条款
  paymentTerms String?  // 付款条款
  liabilityTerms String? // 责任条款

  amount       Float?   // 合同金额
  deposit      Float?   // 保证金

  // 状态
  status       CarrierContractStatus @default(DRAFT) // DRAFT/PENDING/ACTIVE/EXPIRED/TERMINATED

  fileUrl      String?  // 合同文件
  fileName     String?

  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum CarrierContractStatus {
  DRAFT     // 草稿
  PENDING   // 待生效
  ACTIVE    // 生效中
  EXPIRED   // 已过期
  TERMINATED // 已终止
}

// 承运商车辆
model CarrierVehicle {
  id           String   @id @default(uuid())
  carrierId    String
  carrier      Carrier  @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  licensePlate String   // 车牌号
  vehicleType  String   // 车辆类型
  brand        String?  // 品牌
  model        String?  // 型号

  capacity     Float?   // 载重（吨）
  volume       Float?   // 容积（方）

  // 证照信息
  licenseNo    String?  // 行驶证号
  licenseUrl   String?  // 行驶证图片
  insuranceNo  String?  // 保险单号
  insuranceUrl String?  // 保险图片

  // 位置信息
  latitude     Float?   // 当前纬度
  longitude    Float?   // 当前经度
  location     String?   // 当前位置描述
  address      String?   // 详细地址

  // 状态：与运力管理统一
  status       VehicleStatus @default(AVAILABLE) // AVAILABLE/IN_TRANSIT/MAINTENANCE/DISABLED

  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dispatches   Dispatch[]
}

model MaterialBatch {
  id              String    @id @default(uuid())
  batchNo         String    // 批次号
  supplierMaterialId String // 原材料/其他商品ID
  supplierMaterial  SupplierMaterial @relation(fields: [supplierMaterialId], references: [id])
  productionDate  DateTime? // 生产日期
  expiryDate      DateTime? // 有效期
  supplierId      String?   // 供应商ID
  supplier        Supplier?  @relation(fields: [supplierId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inboundItems    InboundOrderItem[]
  materialStocks MaterialStock[]

  @@unique([supplierMaterialId, batchNo])
}

model SKUBatch {
  id              String    @id @default(uuid())
  batchNo         String    // 批次号
  skuId           String    // 商品SKU ID
  sku             ProductSKU @relation(fields: [skuId], references: [id])
  productionDate  DateTime? // 生产日期
  expiryDate      DateTime? // 有效期
  supplierId      String?   // 供应商ID
  supplier        Supplier?  @relation(fields: [supplierId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stocks          Stock[]
  stockLocks      StockLock[]
  stockIns        StockIn[]
  inboundItems    InboundOrderItem[]
  stockOuts       StockOut[]
  pickItems       PickOrderItem[]
  transferItems   StockTransferItem[]

  @@unique([skuId, batchNo])
}

model BundleBatch {
  id              String    @id @default(uuid())
  batchNo         String    // 批次号
  bundleId        String    // 套装SKU ID
  bundle          BundleSKU @relation(fields: [bundleId], references: [id])
  productionDate  DateTime? // 生产日期
  expiryDate      DateTime? // 有效期
  supplierId      String?   // 供应商ID
  supplier        Supplier?  @relation(fields: [supplierId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stocks          BundleStock[]
  stockLocks      BundleStockLock[]
  stockIns        BundleStockIn[]
  stockOuts       StockOut[]
  inboundItems    InboundOrderItem[]
  pickItems       PickOrderItem[]
  transferItems   StockTransferItem[]

  @@unique([bundleId, batchNo])
}
